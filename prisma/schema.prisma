// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Users table - extends authentication service
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  displayName String
  bio       String?  // max 256 chars
  avatarUrl String?  // user avatar URL
  reputation Int     @default(0) // total reputation points
  isPublic  Boolean  @default(true) // whether profile is public
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookmarks        Bookmark[]
  rooms            Room[]           @relation("createdRooms")
  participants     RoomParticipant[]
  submissions      Submission[]
  stats            SessionStats?
  authoredComments Comment[]        @relation("authoredComments")
  userLikes        Like[]           @relation("userLikes")
  sharedSolutions  Solution[]       @relation("sharedSolutions")
  solutionVotes    SolutionVote[]   @relation("solutionVotes")
  badges           Badge[]          @relation("userBadges")
  followers        Follow[]         @relation("userFollowers")
  following        Follow[]         @relation("userFollowing")
  leaderboardEntries Leaderboard[]  @relation("userLeaderboard")

  @@map("users")
}

// Bookmarks - user's saved problems
model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  problemSlug String
  title       String
  difficulty  String   // "Easy", "Medium", "Hard"
  topics      String?  // JSON array stored as string
  notes       String?
  isSolved    Boolean  @default(false)
  bookmarkedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@index([userId])
  @@index([difficulty])
  @@map("bookmarks")
}

// Rooms - collaboration sessions
model Room {
  id              String   @id @default(cuid())
  creatorId       String
  title           String?
  problemSlug     String?
  language        String   // "python", "javascript", "java", "cpp"
  accessLevel     String   @default("PUBLIC") // "PUBLIC", "INVITE", "PRIVATE"
  isActive        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  documentState   String?  // Base64-encoded Yjs document state
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  closedAt        DateTime?

  creator      User              @relation("createdRooms", fields: [creatorId], references: [id], onDelete: Cascade)
  participants RoomParticipant[]
  submissions  Submission[]

  @@index([creatorId])
  @@index([isArchived])
  @@map("rooms")
}

// Room participants - track who is in each room
model RoomParticipant {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  role      String   @default("participant") // "creator", "participant"
  joinedAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_participants")
}

// Submissions - code submissions during collaboration
model Submission {
  id            String   @id @default(cuid())
  roomId        String
  userId        String
  code          String
  language      String
  status        String   // "pending", "running", "success", "error"
  totalTests    Int      @default(0)
  passedTests   Int      @default(0)
  testResults   Json?    // Array of test results
  executionTime Int?     // milliseconds
  memory        Int?     // bytes
  timestamp     DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@index([timestamp])
  @@map("submissions")
}

// Session stats - aggregated user statistics
model SessionStats {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  problemsSolved           Int      @default(0)
  languagesPracticed       String?  // JSON array of languages stored as string
  totalCollaborationTime   Int      @default(0) // seconds
  lastActivityAt           DateTime @default(now()) @updatedAt
  monthYear                String   // "2024-01" format for monthly tracking
  createdAt                DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([monthYear])
  @@map("session_stats")
}

// Comments - problem discussions
model Comment {
  id              String   @id @default(cuid())
  authorId        String
  problemSlug     String   // indexed
  content         String
  likes           Int      @default(0)
  parentCommentId String?  // for threaded replies
  isEdited        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author        User      @relation("authoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("commentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("commentReplies")
  likedBy       Like[]

  @@index([problemSlug, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

// Likes - comment likes
model Like {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation("userLikes", fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([userId])
  @@map("likes")
}

// Solutions - shared code solutions
model Solution {
  id          String   @id @default(cuid())
  authorId    String
  problemSlug String   // indexed
  code        String
  language    String
  explanation String?
  upvotes     Int      @default(0)
  views       Int      @default(0)
  isApproved  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User             @relation("sharedSolutions", fields: [authorId], references: [id], onDelete: Cascade)
  votes  SolutionVote[]

  @@index([problemSlug, upvotes])
  @@index([authorId])
  @@map("solutions")
}

// Solution votes - upvotes/downvotes on solutions
model SolutionVote {
  id         String   @id @default(cuid())
  userId     String
  solutionId String
  voteType   String   // "upvote" | "downvote"
  createdAt  DateTime @default(now())

  user     User     @relation("solutionVotes", fields: [userId], references: [id], onDelete: Cascade)
  solution Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@unique([userId, solutionId])
  @@index([userId])
  @@map("solution_votes")
}

// Badges - achievements earned by users
model Badge {
  id         String   @id @default(cuid())
  userId     String
  badgeType  String   // "first_solution", "10_solutions", "helpful_comment", "top_contributor"
  earnedAt   DateTime @default(now())

  user User @relation("userBadges", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId, badgeType])
  @@map("badges")
}

// Following - user follow relationships
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("userFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("userFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// Leaderboard - user rankings in categories
model Leaderboard {
  id              String   @id @default(cuid())
  userId          String
  category        String   // "global", "python", "javascript", "java", "cpp"
  rank            Int
  score           Int      @default(0) // weighted score
  problemsSolved  Int      @default(0)
  solutionsShared Int      @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation("userLeaderboard", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([category, rank])
  @@index([userId, category])
  @@map("leaderboards")
}
