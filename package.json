  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"cd server && pnpm dev\"",
    "build": "next build && cd server && pnpm build",
    "start": "concurrently \"next start\" \"cd server && pnpm start\"",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
